{
  "name": "grindstone",
  "version": "1.20.0",
  "description": "Turn any inline-tagged line into a spaced-repetition (SM-2) review card.",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production && node scripts/release-gate.mjs",
    "gen-keys": "node scripts/gen-keys.mjs",
    "sign-token": "node scripts/sign-token.mjs"
  },
  "keywords": [
    "obsidian",
    "spaced-repetition",
    "srs",
    "sm2"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.11.0",
    "builtin-modules": "^3.3.0",
    "esbuild": "0.20.0",
    "obsidian": "latest",
    "tslib": "2.6.2",
    "typescript": "5.3.3"
  },
  "dependencies": {
    "@noble/ed25519": "^2.3.0",
    "@noble/hashes": "^1.8.0"
  }
}
